d966110e11af"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"pAefnext", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"pAnext", "+", "pBnext"}], "/.", "ChangeOfVariable"}], "//", 
    "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DiffSeries", " ", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Series", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"pAefnext", "-", "pAef"}], "/.", "Fitness"}], "/.", 
         "SSWMApprox"}], "/.", 
        RowBox[{"{", 
         RowBox[{"pAef", "->", 
          RowBox[{"pAef1", " ", "\[Epsilon]"}]}], " ", "}"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Epsilon]", ",", "0", ",", "2"}], "}"}]}], "]"}], "/.", 
     "EffectiveFitness"}], "//", "FullSimplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
