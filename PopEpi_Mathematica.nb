   RowBox[{
    RowBox[{"pas", " ", "=", " ", 
     RowBox[{"pa", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"pA", " ", "wAa"}], " ", "+", 
        RowBox[{"pa", " ", "waa"}], " ", "+", " ", 
