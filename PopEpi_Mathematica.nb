Cell[TextData[{
 "Note there while the conditions satisfy local stability, it should be noted \
that there are equilibria that share common locally stable regimes, where the \
equilibrium is decided by the starting condition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", 
     RowBox[{"A", ",", "0"}]], " ", "=", " ", "1"}], TraditionalForm]],
  ExpressionUUID->"ed497ec0-dbe5-403d-9f79-de425ffea272"],
 ". For instance, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["\[Mu]", 
      SubscriptBox["a", "ef"]], 
     RowBox[{"saaeff", "-", "sAaeff"}]], "+", 
    RowBox[{"O", "(", 
     SuperscriptBox["\[Epsilon]", "2"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"d1b60d8c-7c70-4b20-9837-25338fdcd005"],
 " is locally stable even when sAAeff > sAaeff < saaeff along with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-"}], TraditionalForm]],ExpressionUUID->
  "2db461e1-fa55-4776-97fd-70f8d7ddf4da"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["\[Mu]", 
      SubscriptBox["A", "ef"]], 
     RowBox[{"sAAeff", "-", "sAaeff"}]], "+", 
    RowBox[{"O", "(", 
     SuperscriptBox["\[Epsilon]", "2"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"d6b8fc2d-196b-436b-95a8-50abbd787b51"],
 " but the later will be attained first starting with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", 
     RowBox[{"A", ",", "0"}]], "=", "1."}], TraditionalForm]],ExpressionUUID->
  "df7013c7-83d2-4d7a-adb6-514c4a994dd8"]
}], "Subsubsection",
 CellChangeTimes->{{3.945311344459096*^9, 3.945311391840166*^9}, {
  3.9453114414770727`*^9, 
  3.945311582567644*^9}},ExpressionUUID->"5094e0ad-1c93-41a2-9527-\
60c5057ac4f4"]
}, Closed]]
}, Closed]],

