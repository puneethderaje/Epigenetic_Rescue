         RowBox[{"panext", "-", "pa"}], "/.", "ChangeOfVariable"}], "/.", 
        "Fitness"}], "/.", "Case1Assump"}], "/.", "Case1Fitness"}], "/.", 
     RowBox[{"h", "->", "0"}]}], "//", "FullSimplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"padiffSeries", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Series", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"%", "/.", 
           RowBox[{"fA", "->", "fA0solSerieslesshalf"}]}], "/.", 
          RowBox[{"pAef", "->", 
           RowBox[{"1", "-", "pa"}]}]}], "/.", 
