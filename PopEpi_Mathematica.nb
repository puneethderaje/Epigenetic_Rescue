       RowBox[{"(", 
        RowBox[{
         RowBox[{"pA", " ", "wAa"}], "+", 
         RowBox[{"pb", " ", "wab"}]}], ")"}], "pa"}], " ", "+", " ", 
      RowBox[{"\[Mu]", " ", "pAs"}], " ", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Nu]"}], ")"}], "ta", " ", "pbs"}]}]}], " ", 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pAmut", " ", "=", " ", 
