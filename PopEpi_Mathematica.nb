Cell[CellGroupData[{

Cell[TextData[{
 "Note the numerator can be separated in two terms, (1-fb)\[Mu] + fb \[Nu], \
which is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Mu]", 
    SubscriptBox["a", "ef"]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "209858b7-cafe-437e-8da9-9ecbb626c334"],
 ". Therefore we can split pAef2 as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["\[Mu]", 
      SubscriptBox["a", "ef"]], 
     RowBox[{"saaeff", "-", "sAaeff"}]], "+", 
    RowBox[{
     RowBox[{"O", "(", 
      SuperscriptBox["\[Epsilon]", "2"], ")"}], ".", " "}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "65dd1178-d2fc-45fb-a75a-d4836832b091"]
}], "Subsubsection",
