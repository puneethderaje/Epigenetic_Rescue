Cell[TextData[{
 StyleBox["The equilibrium is given by  ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["1", 
      RowBox[{" ", 
       OverscriptBox["ta", "~"]}]], 
     SqrtBox[
      FractionBox["\[Mu]", 
       RowBox[{" ", "s", " "}]]]}], "-", 
    FractionBox[
     RowBox[{"\[Mu]", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Nu]", "-", "\[Mu]"}], ")"}], " ", 
       OverscriptBox["ma", "~"]}]}], 
     RowBox[{"2", " ", "s", " ", 
      SuperscriptBox[
       OverscriptBox["ta", "~"], "2"]}]], "+", 
    RowBox[{"O", "(", 
     SuperscriptBox["\[Epsilon]", "3"], ")"}]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"6bddfbc8-760e-4b91-b84b-af18d0b754a9"],
 StyleBox[" when ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["ta", "~"], "<", 
    SqrtBox[
     FractionBox["\[Mu]", 
      RowBox[{" ", "s", " "}]]]}], TraditionalForm]],
  FormatType->TraditionalForm,
  FontWeight->"Bold",ExpressionUUID->"b3be7428-1704-4478-9311-395ecb312829"],
 StyleBox[" and ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["\[Mu]", 
     RowBox[{"\[Mu]", "+", "\[Nu]"}]], "-", 
    FractionBox[
     RowBox[{"\[Mu]", " ", 
      OverscriptBox["ta", "~"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Mu]", "-", "\[Nu]"}], ")"}], " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"\[Mu]", "+", "\[Nu]"}], ")"}], "2"]}], "+", 
        RowBox[{"s", " ", "\[Mu]", " ", "\[Nu]", " ", 
         OverscriptBox["ta", "~"]}]}], ")"}]}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"\[Mu]", "+", "\[Nu]"}], ")"}], "4"]], "+", 
    RowBox[{"O", "(", 
     SuperscriptBox["\[Epsilon]", "3"], ")"}], " "}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"a7a5982b-5a4d-410d-8b9b-190c788258a0"],
 StyleBox["otherwise. ",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.949536428147318*^9, 3.949536526162512*^9}, {
  3.949536557682095*^9, 
  3.949536677766267*^9}},ExpressionUUID->"c12c8b46-d846-4f25-b498-\
6df6f9af5e5e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Case 2 : No dominance but the epigenetic allele can have different fitness \
from the mutant.  \
\>", "Subsubsection",
 CellChangeTimes->{{3.949580036700037*^9, 3.949580066252432*^9}, {
  3.94958062371879*^9, 
  3.9495806238641253`*^9}},ExpressionUUID->"174d43ed-8419-40cf-ae4f-\
ffb230f9c184"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Case2Assump", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"sAa", "->", 
      RowBox[{
       RowBox[{"1", "/", "2"}], 
       RowBox[{"(", 
        RowBox[{"sAA", "+", "saa"}], ")"}]}]}], ",", " ", 
     RowBox[{"sAb", "->", 
      RowBox[{
       RowBox[{"1", "/", "2"}], 
       RowBox[{"(", 
        RowBox[{"sAA", "+", "sbb"}], ")"}]}]}], ",", " ", 
     RowBox[{"sab", "->", 
      RowBox[{
       RowBox[{"1", "/", "2"}], 
       RowBox[{"(", 
        RowBox[{"saa", "+", "sbb"}], ")"}]}]}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Case2Fitness", " ", "=", " ", 
  RowBox[{"{", 
   RowBox[{"sAA", "->", "0"}], "}"}]}]}], "Input",
 CellChangeTimes->{{3.9495807619163313`*^9, 3.949580816516914*^9}, {
  3.949580860742778*^9, 3.949580875019973*^9}, {3.949580972706538*^9, 
  3.9495809801680593`*^9}},
 CellLabel->
  "In[290]:=",ExpressionUUID->"3776c209-57d6-47d3-9d73-59b13ed5b1f3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"sAA", "\[Rule]", "0"}], "}"}]], "Output",
 CellChangeTimes->{3.949580950446938*^9, 3.949580980499156*^9},
 CellLabel->
  "Out[291]=",ExpressionUUID->"4e91495f-b723-4ac1-ad08-6e9657b4323b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"pAdiff", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"pAnext", "-", "pAef"}], "/.", 
        RowBox[{"pAef", "->", 
         RowBox[{"1", "-", "paef"}]}]}], "/.", "ChangeOfVariable"}], "/.", 
      "Fitness"}], "/.", "Case2Assump"}], "/.", "Case2Fitness"}], "//", 
   "FullSimplify"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pAdiffSeries", " ", "=", " ", 
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"%", "/.", 
         RowBox[{"fa", "->", "fa0solSeries"}]}], "/.", 
        RowBox[{"{", 
