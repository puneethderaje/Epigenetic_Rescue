    RowBox[{"DiffSeries", ",", " ", "\[Epsilon]", ",", "2"}], "]"}], "/.", 
   RowBox[{"pAef0", "->", 
    RowBox[{"pAef0sol", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pAef1sol0", " ", "=", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{"%", "==", "0"}], ",", "pAef1"}], "]"}], "//", 
    "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Numerator", "[", 
   RowBox[{"pAef1", "/.", "pAef1sol0"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Denominator", "[", 
    RowBox[{"pAef1", "/.", "pAef1sol0"}], "]"}], "//", "FullSimplify"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"%%", "/", "%"}]}], "Input",
