Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Selection", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"pas", " ", "=", " ", 
     RowBox[{"pa", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"pA", " ", "wAa"}], " ", "+", 
        RowBox[{"pa", " ", "waa"}], " ", "+", " ", 
        RowBox[{"pB", " ", "waB"}], " ", "+", " ", 
        RowBox[{"pb", " ", "wab"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pAs", " ", "=", " ", 
     RowBox[{"pA", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"pA", " ", "wAA"}], " ", "+", 
        RowBox[{"pa", " ", "wAa"}], " ", "+", " ", 
        RowBox[{"pB", " ", "wAB"}], " ", "+", " ", 
        RowBox[{"pb", " ", "wAb"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pBs", " ", "=", " ", 
     RowBox[{"pB", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"pA", " ", "wAB"}], " ", "+", 
        RowBox[{"pa", " ", "waB"}], " ", "+", " ", 
        RowBox[{"pB", " ", "wBB"}], " ", "+", " ", 
        RowBox[{"pb", " ", "wBb"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pbs", " ", "=", " ", 
     RowBox[{"pb", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"pA", " ", "wAb"}], " ", "+", 
        RowBox[{"pa", " ", "wab"}], " ", "+", " ", 
        RowBox[{"pB", " ", "wBb"}], " ", "+", " ", 
        RowBox[{"pb", " ", "wbb"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", "Mutation", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pamut", " ", "=", " ", 
     RowBox[{
      RowBox[{"pas", " ", 
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Mu]"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "-", "ma"}], ")"}]}], " ", "+", " ", 
      RowBox[{"\[Mu]", " ", "pAs"}], " ", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Nu]"}], ")"}], "ta", " ", "pbs"}]}]}], " ", 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pAmut", " ", "=", " ", 
     RowBox[{
      RowBox[{"pAs", " ", 
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Mu]"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "-", "mA"}], ")"}]}], " ", "+", " ", 
      RowBox[{"\[Mu]", " ", "pas"}], " ", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Nu]"}], ")"}], "tA", " ", "pBs"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pBmut", " ", "=", " ", 
     RowBox[{
      RowBox[{"pBs", " ", 
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Nu]"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "-", "tA"}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Mu]"}], ")"}], "mA", " ", "pAs"}], " ", "+", " ", 
      RowBox[{"\[Nu]", " ", "pbs"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"pbmut", " ", "=", " ", 
     RowBox[{
      RowBox[{"pbs", " ", 
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Nu]"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "-", "ta"}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Mu]"}], ")"}], "ma", " ", "pas"}], " ", "+", " ", 
      RowBox[{"\[Nu]", " ", "pBs"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", "Normalization", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"wavg", " ", "=", " ", 
     RowBox[{
     "pamut", " ", "+", " ", "pAmut", " ", "+", " ", "pBmut", " ", "+", " ", 
      "pbmut"}]}], ";"}], " ", "\[IndentingNewLine]", 
