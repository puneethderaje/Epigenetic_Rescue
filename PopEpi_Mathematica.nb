   RowBox[{
    RowBox[{"recursions", " ", "=", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"panext", ",", " ", "pAnext", ",", " ", "pBnext"}], "}"}], "/.", 
      RowBox[{"pb", "->", 
       RowBox[{"1", "-", "pa", "-", "pA", "-", "pB"}]}]}]}], 
    ";"}]}]}]], "Input",
