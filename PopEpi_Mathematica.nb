Cell[TextData[{
 "The two equilibrium for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "A"], TraditionalForm]],ExpressionUUID->
  "d5408ed9-5d4a-4299-ab8b-f5609749a7d1"],
 " are therefore, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["\[Mu]", 
      SubscriptBox["a", "ef"]], 
     RowBox[{"saeff", "-", "sAeff"}]], "+", 
    RowBox[{
     RowBox[{"O", "(", 
      SuperscriptBox["\[Epsilon]", "2"], ")"}], " ", "and", " ", "1"}], "-", 
    FractionBox[
     SubscriptBox["\[Mu]", 
      SubscriptBox["A", "ef"]], 
     RowBox[{"sAeff", "-", "saeff"}]], "+", 
    RowBox[{
     RowBox[{"O", "(", 
      SuperscriptBox["\[Epsilon]", "2"], ")"}], "."}]}], TraditionalForm]],
  ExpressionUUID->"87242269-dae9-407a-9a27-f3f19c7f9742"],
 " "
}], "Subsubsection",
