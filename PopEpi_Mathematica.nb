Cell[BoxData[{
 RowBox[{
  RowBox[{"padiff", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"panext", "-", "pa"}], "/.", "ChangeOfVariable"}], "/.", 
       "Fitness"}], "/.", "Case1Assump"}], "/.", "Case1Fitness"}], "//", 
    "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"padiffSeries", " ", "=", " ", 
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"%", "/.", 
          RowBox[{"fA", "->", "fA0solSerieslesshalf"}]}], "/.", 
         RowBox[{"pAef", "->", 
          RowBox[{"1", "-", "pa"}]}]}], "/.", 
        RowBox[{"{", 
         RowBox[{"pa", "->", 
          RowBox[{"pa0", "+", 
           RowBox[{"pa1", " ", "\[Epsilon]"}]}]}], "}"}]}], "/.", 
       "SSWMApprox"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Epsilon]", ",", "0", ",", "2"}], "}"}]}], "]"}], "//", 
    "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Coefficient", "[", 
         RowBox[{"padiffSeries", ",", "\[Epsilon]", ",", "1"}], "]"}], "==", 
        "0"}], ",", "pa0"}], "]"}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{"0", "<", 
        OverscriptBox["mA", "~"], "<", 
        RowBox[{"1", "/", "2"}]}], "}"}]}]}], "]"}], "/.", 
   "EffectiveFitness"}], "//", "FullSimplify"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Coefficient", "[", 
     RowBox[{"padiffSeries", ",", "\[Epsilon]", ",", "2"}], "]"}], "/.", 
    RowBox[{"pa0", "->", "0"}]}], "//", "FullSimplify"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"%", "==", "0"}], ",", "pa1"}], "]"}], "/.", 
   "EffectiveFitness"}], "//", "FullSimplify"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Coefficient", "[", 
