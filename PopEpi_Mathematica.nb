Cell[CellGroupData[{

Cell["\<\
Case 1 : Epigenetically modified allele has the same fitness' as the other \
genetic allele . \
\>", "Subsubsection",
 CellChangeTimes->{{3.950132712147109*^9, 
  3.95013271407556*^9}},ExpressionUUID->"a40a0c17-af9a-42b3-b8e9-\
5523f05ddad1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Case1Assump", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"sBB", "->", "saa"}], ",", " ", 
     RowBox[{"saB", "->", "saa"}], ",", " ", 
     RowBox[{"sAB", "->", "sAa"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Case1Fitness", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"sAA", "->", "0"}], ",", 
     RowBox[{"sAa", "->", " ", 
      RowBox[{
       RowBox[{"-", "h"}], " ", "s"}]}], ",", " ", 
     RowBox[{"saa", "->", " ", 
      RowBox[{"-", "s"}]}]}], "}"}]}], ";"}]}], "Input",
