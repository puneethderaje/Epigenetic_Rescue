Cell[TextData[{
 "To summarize ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["p", "^"], TraditionalForm]],ExpressionUUID->
  "eed74394-7f35-4302-b22b-a1b2a5683419"],
 "A is given by\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-"}], TraditionalForm]],ExpressionUUID->
  "bcec12c7-0a8d-46fc-a02e-df6d36424047"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["\[Mu]", 
      SubscriptBox["A", "ef"]], 
     RowBox[{"sAAeff", "-", "sAaeff"}]], "+", 
    RowBox[{"O", "(", 
     SuperscriptBox["\[Epsilon]", "2"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"7d418854-fa44-4132-b740-8c650853ddf1"],
 " when sAAeff > sAaeff ; \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    SqrtBox[
     FractionBox[
      SubscriptBox["\[Mu]", 
       SubscriptBox["A", "ef"]], 
      RowBox[{"sAAeff", "-", "saaeff"}]]], " ", "+", " ", 
    RowBox[{"O", "(", "\[Epsilon]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "45cd3dc5-0698-49b2-a3da-fdd4024fb3fe"],
 "  when sAAeff = sAaeff > saaeff ;\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     SubscriptBox["\[Mu]", 
      SubscriptBox["a", "ef"]], 
     RowBox[{"saaeff", "-", "sAaeff"}]], "+", 
