Cell[TextData[{
 StyleBox["The equilibrium is given by  ",
  FontSize->19],
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["\[Mu]", 
     RowBox[{"h", " ", "s", " ", 
      OverscriptBox["ta", "~"], " "}]], "-", 
    FractionBox[
     RowBox[{"\[Mu]", " ", 
      RowBox[{"(", " ", 
       RowBox[{
        RowBox[{"\[Mu]", " ", 
         RowBox[{"(", 
          RowBox[{"1", "-", "h"}], ")"}], 
         OverscriptBox["ta", "~"]}], " ", "+", " ", 
        RowBox[{"\[Nu]", " ", "h", " ", 
         OverscriptBox["ma", "~"]}]}], ")"}]}], 
     RowBox[{
      SuperscriptBox["h", "3"], " ", 
      SuperscriptBox["s", "2"], " ", 
      SuperscriptBox[
       OverscriptBox["ta", "~"], "2"]}]], "+", 
    RowBox[{"O", "(", 
     SuperscriptBox["\[Epsilon]", "3"], ")"}]}], TraditionalForm]],
  FontSize->19,ExpressionUUID->"39366397-358e-4b72-a069-b92eed952793"],
 StyleBox[" when ",
  FontSize->19],
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["ta", "~"], " ", ">", " ", 
    RowBox[{
     RowBox[{"O", "(", "\[Epsilon]", ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"roughly", " ", "when", " ", 
        OverscriptBox["ta", "~"]}], "\[GreaterEqual]", " ", 
       FractionBox["\[Mu]", 
        RowBox[{"h", " ", "s"}]]}], ")"}]}]}], TraditionalForm]],
  FontSize->19,ExpressionUUID->"449cc89c-e5ec-4018-909d-7eea178ea8a4"],
 StyleBox[" and ",
  FontSize->19],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["1", 
      OverscriptBox["ta", "~"]], 
     FractionBox[
      RowBox[{"\[Mu]", "+", "\[Nu]"}], 
      RowBox[{"2", " ", "h", " ", "s", " "}]]}], "+", 
    FractionBox["1", "2"], "-", 
    SqrtBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          FractionBox["1", 
           OverscriptBox["ta", "~"]], 
          FractionBox[
           RowBox[{"\[Mu]", "+", "\[Nu]"}], 
           RowBox[{"2", " ", "h", " ", "s", " "}]]}], "+", 
         FractionBox["1", "2"]}], ")"}], "2"], "-", 
      RowBox[{
       FractionBox["1", 
        OverscriptBox["ta", "~"]], 
       FractionBox["\[Mu]", 
        RowBox[{"h", " ", "s", " "}]]}]}]]}], TraditionalForm]],
  FontSize->19,ExpressionUUID->"7973e049-ba22-4111-8036-d25621165d8d"],
