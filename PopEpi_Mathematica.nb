     SuperscriptBox["\[Epsilon]", "2"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"0ec151e6-7d29-46fc-b1bb-46ac13425e85"],
 ", when sAAeff < sAaeff < saaeff ;",
 Cell[BoxData[
  FormBox[" ", TraditionalForm]], "Section",ExpressionUUID->
  "b4d710e1-0413-4fec-a4c2-9d5242f1f920"],
 "\n\n",
 Cell[BoxData[
